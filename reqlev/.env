# ReqLev – Environment Variables
# Copy this file to .env and adjust values before starting the server.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your values
#   uvicorn backend.app.main:app --reload

# ── Database ────────────────────────────────────────────────────────────────
# MySQL connection string – adjust host, port, user, password, dbname
DATABASE_URL=mysql+pymysql://root:@localhost:3306/reqlev

# ── Security ─────────────────────────────────────────────────────────────────
# IMPORTANT: Replace with a long random string in production!
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-in-production-use-a-long-random-string

# JWT algorithm (do not change unless you know what you're doing)
ALGORITHM=HS256

# Session duration in minutes (43200 = 30 days, persists until explicit logout)
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=ReqLev
APP_VERSION=1.0.0
DEBUG=false
